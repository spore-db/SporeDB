# SporeDB Cloud Tier Configuration
# Copy to .env and customize for your deployment.
# All variables use the SPOREDB_ prefix.

# --- Database ---
# PostgreSQL connection string (asyncpg driver required)
SPOREDB_DATABASE_URL=postgresql+asyncpg://sporedb:sporedb@postgres:5432/sporedb

# --- S3-Compatible Object Storage ---
# Endpoint URL for S3-compatible storage (AWS S3, GCP Cloud Storage, Azure Blob, MinIO, Hetzner, etc.)
SPOREDB_S3_ENDPOINT=http://minio:9000
# S3 access credentials
SPOREDB_S3_ACCESS_KEY=minioadmin
SPOREDB_S3_SECRET_KEY=minioadmin
# Bucket name for Parquet data files
SPOREDB_S3_BUCKET=sporedb
# S3 region (used for signature calculation)
SPOREDB_S3_REGION=us-east-1

# --- JWT Authentication ---
# Path to Ed25519 private key for signing tokens
SPOREDB_JWT_SECRET_KEY_PATH=keys/cloud_private.pem
# Path to Ed25519 public key for verifying tokens
SPOREDB_JWT_PUBLIC_KEY_PATH=keys/cloud_public.pem
# JWT algorithm (EdDSA for Ed25519)
SPOREDB_JWT_ALGORITHM=EdDSA
# Access token lifetime in minutes
SPOREDB_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token lifetime in days
SPOREDB_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Application ---
# Application title shown in OpenAPI docs
SPOREDB_APP_TITLE=SporeDB Cloud
# Application version
SPOREDB_APP_VERSION=0.1.0
# Allowed CORS origins (JSON array format)
SPOREDB_CORS_ORIGINS=["http://localhost:3000"]
# Enable debug mode (set to false in production)
SPOREDB_DEBUG=true
